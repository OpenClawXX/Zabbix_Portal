# Secrets / local env — never commit real values
.env
.env.*
!.env.example
.cienv
!.cienv-example

# Claude Code — project settings are committable; local overrides are not
.claude/settings.local.json

# Python
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

