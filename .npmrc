# ── Private registry ──────────────────────────────────────────────────────────
# Uncomment and set to your Artifactory / Nexus npm proxy URL:
# registry=https://artifactory.example.local/api/npm/npm/

# Disable version range resolution beyond what the lockfile specifies.
# This ensures pnpm never hits the registry to resolve a newer patch/minor.
prefer-frozen-lockfile=true

# Never auto-install peer dependencies — keeps installs deterministic.
auto-install-peers=false

# Strict mode: fail if the lockfile would need to be updated.
# Keeps CI and private-network installs from silently drifting.
frozen-lockfile=true

# Do not check for engine compatibility — avoids false failures on
# private registry mirrors that strip `engines` metadata.
engine-strict=false

# Disable telemetry (no outbound calls from the registry client).
update-notifier=false
