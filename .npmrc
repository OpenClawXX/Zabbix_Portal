# ── Private registry ──────────────────────────────────────────────────────────
# Uncomment and set to your Artifactory / Nexus npm proxy URL:
# registry=https://artifactory.example.local/api/npm/npm/

# Always save exact versions (no ^ or ~) when running npm install.
save-exact=true

# Disable update notifier — avoids outbound calls from the npm client.
update-notifier=false
