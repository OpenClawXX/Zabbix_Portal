# VCS / CI / deployment config — none of this belongs in the image
.git
.gitignore
.gitlab
.github
argocd
helm

# Documentation
*.md
LICENCE*

# Local dev config
docker-compose.yml
nginx.compose.conf
package-lock.json
.cienv
.cienv-example
.claude/

# Backend Python source — the frontend build only needs apps/backend/package.json
# for turbo workspace graph resolution; the Python source itself is irrelevant
apps/backend/*.py
apps/backend/requirements.txt
apps/backend/Dockerfile

# Backend runtime artifacts
apps/backend/venv/
apps/backend/.venv/
apps/backend/__pycache__/
apps/backend/*.py[cod]
apps/backend/.pytest_cache/
apps/backend/.mypy_cache/
apps/backend/coverage/
apps/backend/.coverage
apps/backend/htmlcov/

# Frontend build / runtime artifacts (rebuilt inside the container)
**/node_modules/
apps/frontend/dist/
apps/frontend/.vite/
apps/frontend/package-lock.json

# TypeScript incremental build / Turborepo cache
*.tsbuildinfo
.turbo/
**/.turbo/

# Test coverage
coverage/
.coverage
htmlcov/
.nyc_output/

*.log
.DS_Store
Thumbs.db

# Secrets — never bake into any image
apps/backend/.env
apps/backend/.env.*
apps/frontend/.env
apps/frontend/.env.*
