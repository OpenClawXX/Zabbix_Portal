# =============================================================================
# .cienv-example
# =============================================================================
# Every environment variable this repo's CI/CD pipeline depends on.
#
# Deployment today runs via direct `helm upgrade --install` from GitLab CI
# (see .gitlab/ci/gitops.yml). The ArgoCD variables in section 9 are for the
# PLANNED future GitOps migration and are NOT consumed by the current pipeline.
#
# Set these as GitLab CI/CD Variables: Settings → CI/CD → Variables.
# Mark every token/secret as "Masked" + "Protected".
#
# A local .cienv copy is gitignored — never commit real values.
# =============================================================================


# ─── 1. PROJECT IDENTITY ─────────────────────────────────────────────────────
# Helm release name + the chart directory name (helm/charts/<PROJECT_NAME>).
# Used throughout gitops.yml.

PROJECT_NAME=zabbix-portal


# ─── 2. MONOREPO PATHS ───────────────────────────────────────────────────────
# Informational — the CI files reference these paths directly.

BACKEND_PATH=apps/backend
FRONTEND_PATH=apps/frontend


# ─── 3. CONTAINER REGISTRY ───────────────────────────────────────────────────
# The Artifactory registry path is HARDCODED in the CI files, not a variable.
# Replace every <your-artifactory-registry> placeholder — the full list of
# locations is in PRIVATE_NETWORK.md (section 4). Images are pushed as:
#     <your-artifactory-registry>/backend:<tag>
#     <your-artifactory-registry>/frontend:<tag>
#
# CI_REGISTRY_* are provided automatically by GitLab if you use its registry.


# ─── 4. HELM ─────────────────────────────────────────────────────────────────
# HELM_CHART_PATH = path to the umbrella chart that CI installs.
# The image tags are pinned at deploy time with `helm --set backend.image.tag=`
# and `--set frontend.image.tag=` — the keys 'backend' / 'frontend' are the
# sub-chart aliases declared in the umbrella Chart.yaml dependencies.

HELM_CHART_PATH=helm/charts/zabbix-portal


# ─── 5. KUBERNETES NAMESPACE ─────────────────────────────────────────────────
# Pre-created in OpenShift. Used as the Helm install namespace for every env.
# (detect.yml `validate:variables` hard-fails if this is missing.)

K8S_NAMESPACE=zabbix-portal


# ─── 6. CLUSTER DEPLOY ACCESS (CI SECRETS) ───────────────────────────────────
# The deploy jobs pass these to Helm as HELM_KUBEAPISERVER / HELM_KUBETOKEN to
# talk to each cluster's API directly. DR reuses the production cluster by
# default (change the deploy:dr job if DR has its own cluster).
# Mark the tokens as Masked + Protected. validate:variables fails if any is unset.

STAGING_SERVER=https://api.staging-cluster.example.com:6443
STAGING_TOKEN=<paste-staging-serviceaccount-token>

PROD_SERVER=https://api.prod-cluster.example.com:6443
PROD_TOKEN=<paste-production-serviceaccount-token>


# ─── 7. ENVIRONMENT URLS ─────────────────────────────────────────────────────
# Shown in the GitLab "environments" dashboard — no functional impact.

STAGING_URL=https://staging.zabbix-portal.example.com
PRODUCTION_URL=https://zabbix-portal.example.com
DR_URL=https://dr.zabbix-portal.example.com


# ─── 8. TOOLING VERSIONS ─────────────────────────────────────────────────────
# Pin these so pipeline reruns are reproducible and private-network admins know
# exactly which images to mirror. The CI runner tag and Kaniko/Python/Node/Helm
# images are set as <placeholder> values in .gitlab/ci/common.yml + the job
# files — see PRIVATE_NETWORK.md (section 3).

NODE_VERSION=22
PYTHON_VERSION=3.12
HELM_VERSION=3.17.0


# ─── 9. ARGOCD (PLANNED — NOT USED BY THE CURRENT PIPELINE) ───────────────────
# The argocd/ directory holds AppProject / ApplicationSet / per-env values for
# a future migration from direct Helm to ArgoCD-reconciled GitOps. None of the
# variables below are read by today's pipeline. Fill them in only when you
# switch the deploy jobs over to `argocd app set` / `argocd app sync`.
#
# ARGOCD_NAMESPACE=argocd
# ARGOCD_APP_STAGING=zabbix-portal-staging
# ARGOCD_APP_PRODUCTION=zabbix-portal-production
# ARGOCD_SERVER=argocd.example.com
# ARGOCD_AUTH_TOKEN=<paste-argocd-service-account-token>
# ARGOCD_CLI_VERSION=v2.14.0
# REPO_URL=https://gitlab.example.com/your-org/zabbix-portal.git   # used by argocd manifests
# PROD_TARGET_REVISION=HEAD                                        # used by argocd/application.yaml


# ─── 10. PRIVATE-NETWORK MIRRORS (optional) ──────────────────────────────────
# If set, the Dockerfiles and build jobs can be patched to read from these.
# The Dockerfiles currently have these as comments — see PRIVATE_NETWORK.md.
#
# PRIVATE_DOCKER_REGISTRY=artifactory.example.local/docker-virtual
# PRIVATE_NPM_REGISTRY=https://artifactory.example.local/api/npm/npm/
# PRIVATE_PYPI_INDEX=https://artifactory.example.local/api/pypi/pypi/simple


# ─── 11. APP RUNTIME SECRETS ─────────────────────────────────────────────────
# These are NOT consumed by CI — they live in a Kubernetes Secret + ConfigMap
# (names set via `existingSecret` / `existingConfigMap` in the umbrella
# values.yaml; defaults: backend-secret / backend-config). Create them in each
# cluster before deploying. PostgreSQL is shared/external — DATABASE_URL points
# the backend at it.
#
# kubectl -n $K8S_NAMESPACE create secret generic backend-secret \
#   --from-literal=ZABBIX_USER=Admin \
#   --from-literal=ZABBIX_PASS=<password> \
#   --from-literal=SECRET_KEY=<long-random-string> \
#   --from-literal=DATABASE_URL=postgresql://user:password@host:5432/zabbix_portal
#
# kubectl -n $K8S_NAMESPACE create configmap backend-config \
#   --from-literal=ZABBIX_URL=https://your-zabbix-server
