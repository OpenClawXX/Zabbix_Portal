# =============================================================================
# .cienv-example
# =============================================================================
# Every environment variable this repo's CI/CD and ArgoCD bootstrap depend on.
#
# Two consumers read these:
#
#   1. GitLab CI/CD pipeline  → set the values below as CI/CD Variables
#                               (Settings → CI/CD → Variables, mark secrets as
#                               "Masked" + "Protected")
#
#   2. argocd/bootstrap.sh    → copy this file to .cienv at repo root, fill in
#                               values, run ./argocd/bootstrap.sh
#
# The .cienv file is gitignored — never commit it.
# =============================================================================


# ─── 1. PROJECT IDENTITY ─────────────────────────────────────────────────────
# A short, kebab-case slug used as a prefix for the ArgoCD project, the K8s
# namespace, image names, ingress hostnames, etc. Change this for every new
# project — most other values can stay default.

PROJECT_NAME=zabbix-portal


# ─── 2. MONOREPO PATHS ───────────────────────────────────────────────────────
# Change these only if the apps live under different paths in your repo.

BACKEND_PATH=apps/backend
FRONTEND_PATH=apps/frontend


# ─── 3. CONTAINER REGISTRY ───────────────────────────────────────────────────
# CI_REGISTRY, CI_REGISTRY_USER, CI_REGISTRY_PASSWORD, and CI_REGISTRY_IMAGE
# are provided automatically by GitLab — do NOT set them manually.
#
# Override the image *names* (suffix appended to CI_REGISTRY_IMAGE) only if
# you want non-default repository names.

BACKEND_IMAGE_NAME=backend
FRONTEND_IMAGE_NAME=frontend


# ─── 4. HELM ─────────────────────────────────────────────────────────────────
# HELM_CHART_PATH = path to the umbrella chart that CI installs/syncs.
# *_HELM_KEY      = sub-chart keys as referenced by the umbrella chart's
#                    values.yaml. These are what `argocd app set --helm-set
#                    <KEY>.image.tag=...` targets in the production deploy job.

HELM_CHART_PATH=helm/charts/zabbix-portal
BACKEND_HELM_KEY=zabbix-portal-backend
FRONTEND_HELM_KEY=zabbix-portal-frontend


# ─── 6. KUBERNETES ───────────────────────────────────────────────────────────

K8S_NAMESPACE=zabbix-portal
IN_CLUSTER_SERVER=https://kubernetes.default.svc


# ─── 7. ARGOCD APPLICATIONS ──────────────────────────────────────────────────
# Names of the ArgoCD Application objects that the staging/production deploy
# jobs target. These must match the Application names generated by the
# ApplicationSet (see argocd/applicationset.yaml).

ARGOCD_NAMESPACE=argocd
ARGOCD_APP_STAGING=zabbix-portal-staging
ARGOCD_APP_PRODUCTION=zabbix-portal-production

# Used only by argocd/application.yaml (the single, manually-managed app).
# Not used by ApplicationSet.
PROD_TARGET_REVISION=HEAD


# ─── 8. ARGOCD ACCESS (CI SECRET) ────────────────────────────────────────────
# Set as CI/CD Variables (masked + protected). The deploy:staging and
# deploy:production jobs use these to call `argocd app sync`.

ARGOCD_SERVER=argocd.example.com
ARGOCD_AUTH_TOKEN=<paste-argocd-service-account-token>


# ─── 9. REPOSITORY URL ───────────────────────────────────────────────────────
# Used by argocd/application.yaml and argocd/applicationset.yaml to point
# ArgoCD at the Helm chart in this monorepo.

REPO_URL=https://gitlab.example.com/your-org/zabbix-portal.git


# ─── 10. ENVIRONMENT URLS ────────────────────────────────────────────────────
# Used purely for the GitLab "environments" dashboard — no functional impact.

STAGING_URL=https://staging.zabbix-portal.example.com
PRODUCTION_URL=https://zabbix-portal.example.com


# ─── 11. TOOLING VERSIONS ────────────────────────────────────────────────────
# Pinning these here makes pipeline reruns reproducible and signals to
# private-network admins exactly which images need to be mirrored.

NODE_VERSION=22
PYTHON_VERSION=3.12
HELM_VERSION=3.17.0
ARGOCD_CLI_VERSION=v2.14.0


# ─── 12. PRIVATE-NETWORK MIRRORS (optional) ──────────────────────────────────
# If set, the Dockerfiles and build jobs can be patched to read from these.
# Currently the Dockerfiles have these as comments — uncomment + use them
# in a build hook if you operate fully air-gapped.
#
# PRIVATE_DOCKER_REGISTRY=artifactory.example.local/docker-virtual
# PRIVATE_NPM_REGISTRY=https://artifactory.example.local/api/npm/npm/
# PRIVATE_PYPI_INDEX=https://artifactory.example.local/api/pypi/pypi/simple


# ─── 13. APP RUNTIME SECRETS ─────────────────────────────────────────────────
# These are NOT consumed by CI itself — they live in a Kubernetes Secret
# (`zabbix-portal-backend-secret` by default, see helm/charts/backend/values.yaml
# `existingSecret`). Listed here for completeness so you remember to create
# the Secret in each cluster before deploying.
#
# kubectl -n $K8S_NAMESPACE create secret generic zabbix-portal-backend-secret \
#   --from-literal=ZABBIX_URL=https://your-zabbix-server \
#   --from-literal=ZABBIX_USER=Admin \
#   --from-literal=ZABBIX_PASS=<password> \
#   --from-literal=SECRET_KEY=<long-random-string> \
#   --from-literal=DATABASE_URL=postgresql://user:password@host:5432/zabbix_portal
