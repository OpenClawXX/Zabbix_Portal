# VCS
.git
.gitignore

# Node workspace manifest — not needed in Python image
package.json

# Python runtime artifacts
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Test coverage
coverage/
.coverage
htmlcov/
.nyc_output/

# Node artifacts (shouldn't exist here but exclude defensively)
node_modules/
dist/

# Documentation
*.md

*.log
.DS_Store

# Secrets — injected at runtime via docker-compose env_file or Kubernetes Secret
.env
.env.*
